APIFY_TOKEN=your_apify_api_token_here
CLAUDE_API_KEY=your_claude_api_key_here
PORT=3000

# Optional. Claude model used for negotiation + brand-fit scoring.
# Defaults to claude-sonnet-5. Use claude-opus-4-8 for higher quality.
# CLAUDE_MODEL=claude-sonnet-5

# Optional. Only needed for the "local headless login" connect method.
# Path to a Chromium binary if Playwright can't find one automatically.
# CHROMIUM_PATH=/opt/pw-browsers/chromium/chrome-linux/chrome

# Optional. "Log in via Apify" connect method. By default the app tries a
# built-in list of login actors in order and uses the first that returns valid
# cookies. Set IG_LOGIN_ACTOR_ID to force a single actor (plus the field-name
# overrides if that actor uses different input keys, e.g. email vs username).
# IG_LOGIN_ACTOR_ID=zen-studio~instagram-login
# IG_LOGIN_USER_FIELD=email
# IG_LOGIN_PASS_FIELD=password
# IG_LOGIN_CODE_FIELD=code
