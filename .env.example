APIFY_TOKEN=your_apify_api_token_here
CLAUDE_API_KEY=your_claude_api_key_here
PORT=3000

# Optional. Claude model used for negotiation + brand-fit scoring.
# CLAUDE_MODEL=claude-sonnet-4-20250514

# Optional. Only needed for the "local headless login" connect method.
# Path to a Chromium binary if Playwright can't find one automatically.
# CHROMIUM_PATH=/opt/pw-browsers/chromium/chrome-linux/chrome

# Optional. "Log in via Apify" connect method — runs a login actor on Apify
# and stores the returned cookies (no browser on this server). Override the
# actor and its input field names if you use a different login actor.
# IG_LOGIN_ACTOR_ID=shareze001~instagram-cookies
# IG_LOGIN_USER_FIELD=username
# IG_LOGIN_PASS_FIELD=password
# IG_LOGIN_CODE_FIELD=code
